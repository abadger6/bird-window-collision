# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.ipynb_checkpoints/

# uv
.python-version

# Env / secrets
.env
.env.*
!.env.example
# Earth Engine credentials — never commit
.config/earthengine/
ee_credentials.json
service-account*.json

# Data outputs (regenerated by pipeline). data/cities/ contents are
# regeneratable via scripts/fetch_overture_city.py; keep the dir tracked.
data/*
!data/cities/
data/cities/*
!data/cities/.gitkeep
*.gpkg
*.parquet
*.tif

# osmnx cache — regenerable, large; osmnx creates this at cwd/cache by default
cache/

# OS
.DS_Store

# React/Vite viewer app
web/node_modules/
web/dist/
web/.vite/

# Local preview server support (Claude Code)
.claude/preview-root/
